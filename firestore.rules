rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check - Robust identification
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.uid == "zVnYHORDdQTfJRWzeiAMKVsgoVz2" || 
             (request.auth.token.email == "janiceleroy@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidValuation(data) {
      return data.keys().hasAll(['userId', 'commune', 'estimated_price_uf', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.commune is string && data.commune.size() < 100 &&
             data.estimated_price_uf is number &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Collection Matches
    // ===============================================================

    // Public Collections
    match /projects/{projectId} {
      // Permitir lectura pública de proyectos (get y list)
      allow read: if true;
      // Solo administradores pueden crear o editar proyectos
      allow write: if isAdmin();
    }

    // User Private Collections
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /valuations/{valuationId} {
      // Secure list query enabled via resource.data.userId check
      // Optimizamos para no requerir índices compuestos en la mayoría de los casos
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Permitir creación si está logueado y es el dueño
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      
      // Solo administradores pueden actualizar o borrar
      allow update, delete: if isAdmin();
    }

    // Default Deny Catch-All (SIEMPRE AL FINAL)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
